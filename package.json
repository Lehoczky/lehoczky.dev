{
  "name": "lehoczky-dev",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "pnpm run build && wrangler dev",
    "eslint:check": "eslint . --max-warnings=0",
    "eslint:fix": "eslint . --max-warnings=0 --fix",
    "format:check": "prettier . --check --ignore-unknown --cache",
    "format:fix": "prettier . --write --ignore-unknown",
    "lint": "npm run format:check && npm run eslint:check",
    "lighthouse:check": "lhci autorun",
    "link:check": "linkinator ./dist --skip www.linkedin.com",
    "generate-types": "wrangler types",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.3.0",
    "@astrojs/vue": "^6.0.1",
    "astro": "^6.1.9",
    "clsx": "^2.1.1",
    "reka-ui": "^2.9.6",
    "sal.js": "^0.8.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@iconify-json/bxl": "^1.2.4",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.104",
    "@lehoczky/eslint-config-vue": "^3.0.0",
    "@lehoczky/prettier-config": "^2.0.2",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/vite": "^4.2.4",
    "astro-seo-schema": "^6.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "linkinator": "^7.6.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "schema-dts": "^1.1.5",
    "sharp": "^0.34.5",
    "unplugin-icons": "^23.0.1",
    "wrangler": "^4.87.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "oxc-resolver",
      "sharp",
      "vue-demi"
    ]
  },
  "overrides": {
    "vite": "^7"
  }
}
